backend.db
backend.db-shm
backend.db-wal
backend_BU_*.db
*.sqlite
*.sqlite3

# ─── Python artifacts ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# ─── Virtual environment ───────────────────────────────────────────────────
venv/
.venv/
env/

